{
  "codeConnect": {
    "label": "biz-frontend",
    "parser": "react",
    "include": [
      "components/**/*.{tsx,jsx}",
      "app/**/*.{tsx,jsx}"
    ],
    "exclude": [
      "**/*.test.{tsx,jsx}",
      "**/__tests__/**",
      "node_modules/**",
      ".next/**"
    ],
    "importPaths": {
      "components/*": "@/components"
    },
    "paths": {
      "@/*": ["./*"]
    }
  }
}
